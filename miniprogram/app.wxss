/* 药店网上商城全局样式 */

/* CSS 变量 */
page {
  --primary: #07c160;
  --primary-dark: #059048;
  --price: #e53e3e;
  --bg: #f5f5f5;
  --white: #ffffff;
  --text: #333333;
  --text-light: #666666;
  --text-muted: #999999;
  --border: #e5e5e5;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);

  /* 通用页面背景 */
  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
    'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;

  /* 安全区适配 */
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 通用容器 */
.container {
  padding: 24rpx;
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

/* 价格文字 */
.price {
  color: var(--price);
  font-weight: bold;
}

/* 主色调文字 */
.text-primary {
  color: var(--primary);
}

/* 单行省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 两行省略 */
.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
