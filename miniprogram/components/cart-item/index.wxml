<view class="cart-item">
  <view class="check" bindtap="onToggle">
    <text class="check-icon">{{checked ? '✅' : '⬜'}}</text>
  </view>
  <image wx:if="{{item.image}}" class="img" src="{{item.image}}" mode="aspectFill" />
  <view wx:else class="img-placeholder">📦</view>
  <view class="info">
    <text class="name">{{item.product_name}}</text>
    <view class="price-row">
      <text class="price">{{item.price}}</text>
      <view class="qty">
        <view class="btn" bindtap="onMinus">-</view>
        <text class="num">{{item.quantity}}</text>
        <view class="btn" bindtap="onPlus">+</view>
      </view>
    </view>
  </view>
</view>
