<view class="card" bindtap="onTap">
  <image wx:if="{{product.images && product.images.length && product.images[0]}}" class="img" src="{{product.images[0]}}" mode="aspectFill" lazy-load />
  <view wx:else class="img-placeholder">💊</view>
  <view class="info">
    <text class="name">{{product.name}}</text>
    <text class="spec" wx:if="{{product.specification}}">{{product.specification}}</text>
    <view class="bottom">
      <view class="price-box">
        <text class="price">{{product.price}}</text>
        <text class="sales" wx:if="{{product.sales}}">已售 {{product.sales}}</text>
      </view>
      <view class="add-btn" catchtap="onAddCart">+</view>
    </view>
  </view>
</view>
