<view class="page">
  <view class="form">
    <view class="form-item">
      <text class="label">收货人</text>
      <input class="input" value="{{form.name}}" placeholder="请输入姓名" data-field="name" bindinput="onInput" />
    </view>
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" value="{{form.phone}}" placeholder="请输入手机号" type="number" maxlength="11" data-field="phone" bindinput="onInput" />
    </view>
    <view class="form-item">
      <text class="label">所在地区</text>
      <picker mode="region" value="{{region}}" bindchange="onRegionChange">
        <text class="picker-text">{{form.province ? form.province + ' ' + form.city + ' ' + form.district : '请选择地区'}}</text>
      </picker>
    </view>
    <view class="form-item">
      <text class="label">详细地址</text>
      <textarea class="textarea" value="{{form.detail}}" placeholder="街道、门牌号等" data-field="detail" bindinput="onInput" />
    </view>
    <view class="form-item">
      <text class="label">设为默认</text>
      <switch checked="{{form.is_default}}" bindchange="onToggleDefault" color="#07c160" />
    </view>
  </view>

  <view class="save-btn" bindtap="onSave">保存</view>
</view>
