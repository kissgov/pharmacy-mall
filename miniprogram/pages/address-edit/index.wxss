.page { background: #f5f5f5; min-height: 100vh; padding-bottom: 120rpx; }
.form { background: #fff; margin: 16rpx; border-radius: 12rpx; overflow: hidden; }
.form-item {
  display: flex; align-items: center; padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5; font-size: 28rpx;
}
.form-item:last-child { border-bottom: none; }
.label { width: 160rpx; color: #333; }
.input { flex: 1; color: #333; }
.picker-text { flex: 1; color: #999; }
.textarea { flex: 1; height: 120rpx; color: #333; }
.save-btn {
  margin: 40rpx 16rpx; height: 88rpx; border-radius: 12rpx;
  background: #07c160; color: #fff; font-size: 32rpx;
  text-align: center; line-height: 88rpx;
}
