<view class="page">
  <!-- 管理切换 -->
  <view wx:if="{{items.length}}" class="top-bar">
    <text bindtap="onToggleMode">{{editMode ? '完成' : '管理'}}</text>
  </view>

  <!-- 商品列表 -->
  <view wx:if="{{items.length}}" class="list">
    <cart-item
      wx:for="{{items}}" wx:key="id"
      item="{{item}}" checked="{{item.checked}}"
      bindtoggle="onToggle"
      bindminus="onMinus"
      bindplus="onPlus"
    />
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车是空的</text>
    <view class="go-btn" bindtap="onGoHome">去逛逛</view>
  </view>

  <!-- 底栏 -->
  <view wx:if="{{items.length}}" class="bottom-bar">
    <view class="select-all" bindtap="onToggleAll">
      <image src="{{allChecked ? '/assets/checked.png' : '/assets/unchecked.png'}}" class="check-icon" />
      <text>全选</text>
    </view>
    <block wx:if="{{!editMode}}">
      <view class="total">
        <text>合计: </text>
        <text class="total-price">{{totalAmount}}</text>
      </view>
      <view class="checkout-btn" bindtap="onCheckout">结算</view>
    </block>
    <block wx:else>
      <view class="delete-btn" bindtap="onDelete">删除</view>
    </block>
  </view>
</view>
