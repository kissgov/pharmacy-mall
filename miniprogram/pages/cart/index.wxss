.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 120rpx; }
.top-bar { display: flex; justify-content: flex-end; padding: 16rpx 24rpx; background: #fff; }
.top-bar text { font-size: 28rpx; color: #07c160; }
.list { padding: 16rpx; }
.empty { text-align: center; padding: 200rpx 0; }
.empty-icon { font-size: 100rpx; display: block; }
.empty-text { font-size: 28rpx; color: #999; margin-top: 20rpx; display: block; }
.go-btn {
  margin: 40rpx auto 0; width: 240rpx; height: 72rpx;
  background: #07c160; color: #fff; border-radius: 36rpx;
  font-size: 28rpx; line-height: 72rpx; text-align: center;
}
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.select-all { display: flex; align-items: center; gap: 10rpx; font-size: 28rpx; }
.check-icon { width: 40rpx; height: 40rpx; }
.total { flex: 1; text-align: right; font-size: 28rpx; color: #333; margin-right: 16rpx; }
.total-price { font-size: 34rpx; font-weight: bold; color: #e53e3e; }
.checkout-btn {
  width: 180rpx; height: 72rpx; border-radius: 36rpx;
  background: #07c160; color: #fff; font-size: 30rpx;
  text-align: center; line-height: 72rpx;
}
.delete-btn {
  width: 180rpx; height: 72rpx; border-radius: 36rpx;
  background: #e53e3e; color: #fff; font-size: 30rpx;
  text-align: center; line-height: 72rpx;
}
