<view class="page">
  <view class="container">
    <!-- 左侧一级分类 -->
    <scroll-view class="left" scroll-y>
      <view
        class="cat-item {{activeIndex === index ? 'active' : ''}}"
        wx:for="{{categories}}" wx:key="id"
        data-index="{{index}}"
        bindtap="onCategoryTap"
      >{{item.name}}</view>
    </scroll-view>

    <!-- 右侧内容 -->
    <scroll-view class="right" scroll-y>
      <!-- 子分类 -->
      <view wx:if="{{subCategories.length}}" class="sub-cats">
        <view
          class="sub-item"
          wx:for="{{subCategories}}" wx:key="id"
          data-id="{{item.id}}"
          bindtap="onSubCategoryTap"
        >{{item.name}}</view>
      </view>

      <!-- 商品列表 -->
      <view class="product-grid">
        <product-card wx:for="{{products}}" wx:key="id" product="{{item}}" />
      </view>

      <view wx:if="{{!products.length}}" class="empty">暂无商品</view>
    </scroll-view>
  </view>
</view>
