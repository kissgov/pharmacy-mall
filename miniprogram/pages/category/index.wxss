.page { height: 100vh; display: flex; flex-direction: column; }
.container { display: flex; flex: 1; overflow: hidden; }
.left {
  width: 180rpx; background: #f5f5f5; height: 100%;
}
.cat-item {
  padding: 28rpx 16rpx; font-size: 26rpx; color: #666;
  text-align: center; position: relative;
}
.cat-item.active {
  background: #fff; color: #07c160; font-weight: bold;
}
.cat-item.active::before {
  content: ''; position: absolute; left: 0; top: 20%;
  width: 6rpx; height: 60%; background: #07c160; border-radius: 3rpx;
}
.right { flex: 1; padding: 16rpx; height: 100%; }
.sub-cats { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 20rpx; }
.sub-item {
  padding: 10rpx 20rpx; background: #f5f5f5;
  border-radius: 20rpx; font-size: 24rpx; color: #666;
}
.product-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.product-grid product-card { width: calc(50% - 8rpx); }
.empty { text-align: center; padding: 80rpx 0; color: #999; font-size: 28rpx; }
