.page { background: #f5f5f5; min-height: 100vh; padding-bottom: 120rpx; }
.card { background: #fff; padding: 24rpx; margin: 16rpx; border-radius: 12rpx; }
.address-card { display: flex; align-items: center; }
.addr-info { flex: 1; }
.addr-name { font-size: 30rpx; font-weight: bold; color: #333; display: block; }
.addr-detail { font-size: 24rpx; color: #666; margin-top: 8rpx; display: block; }
.no-addr { flex: 1; font-size: 28rpx; color: #999; }
.arrow { font-size: 36rpx; color: #ccc; }
.item { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.item:last-child { border-bottom: none; }
.item-img { width: 120rpx; height: 120rpx; border-radius: 8rpx; background: #f5f5f5; }
.item-info { flex: 1; margin-left: 16rpx; display: flex; flex-direction: column; justify-content: space-between; }
.item-name { font-size: 26rpx; color: #333; }
.item-bottom { display: flex; justify-content: space-between; align-items: center; }
.item-price { font-size: 28rpx; font-weight: bold; color: #e53e3e; }
.item-qty { font-size: 24rpx; color: #999; }
.row { display: flex; justify-content: space-between; align-items: center; font-size: 28rpx; color: #333; }
.row-right { display: flex; align-items: center; gap: 8rpx; }
.coupon-text { font-size: 24rpx; color: #e53e3e; }
.remark-input { flex: 1; text-align: right; font-size: 26rpx; }
.amount-card { padding: 8rpx 24rpx 24rpx; }
.amount-row { display: flex; justify-content: space-between; padding: 12rpx 0; font-size: 26rpx; color: #666; }
.discount { color: #e53e3e; }
.pay-row { border-top: 1rpx solid #f0f0f0; margin-top: 8rpx; padding-top: 16rpx; }
.pay-amount { font-size: 36rpx; font-weight: bold; color: #e53e3e; }
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; justify-content: flex-end; gap: 16rpx;
  padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.pay-text { font-size: 28rpx; color: #333; }
.submit-btn {
  width: 220rpx; height: 80rpx; border-radius: 40rpx;
  background: #07c160; color: #fff; font-size: 30rpx;
  text-align: center; line-height: 80rpx;
}
.submit-btn.disabled { opacity: 0.6; }
