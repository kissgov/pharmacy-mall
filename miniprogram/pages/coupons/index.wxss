.page { background: #f5f5f5; min-height: 100vh; }
.tabs { display: flex; background: #fff; }
.tab { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #666; position: relative; }
.tab.active { color: #07c160; font-weight: bold; }
.tab.active::after { content: ''; position: absolute; bottom: 0; left: 30%; width: 40%; height: 4rpx; background: #07c160; border-radius: 2rpx; }
.list { padding: 16rpx; }
.coupon-card {
  display: flex; align-items: center; background: #fff;
  border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx;
  position: relative; overflow: hidden;
}
.coupon-card.used { opacity: 0.5; }
.coupon-left {
  width: 160rpx; text-align: center; border-right: 2rpx dashed #eee;
  padding-right: 20rpx;
}
.coupon-value { font-size: 44rpx; font-weight: bold; color: #e53e3e; display: block; }
.coupon-condition { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }
.coupon-right { flex: 1; margin-left: 20rpx; }
.coupon-name { font-size: 28rpx; color: #333; font-weight: bold; display: block; }
.coupon-date { font-size: 22rpx; color: #999; margin-top: 8rpx; display: block; }
.receive-btn {
  padding: 10rpx 24rpx; background: #07c160; color: #fff;
  font-size: 24rpx; border-radius: 24rpx;
}
.status-tag { font-size: 22rpx; color: #999; }
.empty { text-align: center; padding: 200rpx 0; color: #999; font-size: 28rpx; }
