<view class="page">
  <!-- 搜索栏 -->
  <view class="search-bar" bindtap="onSearch">
    <view class="search-input">
      <text class="icon">🔍</text>
      <text class="placeholder">搜索药品、症状</text>
    </view>
  </view>

  <!-- Banner 轮播 -->
  <swiper wx:if="{{banners.length}}" class="banner-swiper" indicator-dots autoplay circular interval="3000">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <view class="banner-placeholder" wx:if="{{!item.image_url || item.image_url.indexOf('placeholder.com')!==-1}}">
        <text class="banner-emoj">{{index===0?'🎁':'💎'}}</text>
        <text class="banner-text">{{item.title}}</text>
      </view>
      <image wx:else src="{{item.image_url}}" mode="aspectFill" class="banner-img" binderror="onBannerError" data-index="{{index}}" />
    </swiper-item>
  </swiper>

  <!-- 分类入口 -->
  <view class="category-grid">
    <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="onCategoryTap">
      <text class="cat-icon">{{item.icon || '📦'}}</text>
      <text class="cat-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 热门推荐 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">热门推荐</text>
      <text class="section-more" bindtap="onSearch">更多 ›</text>
    </view>
    <view class="product-list">
      <product-card wx:for="{{hotProducts}}" wx:key="id" product="{{item}}" />
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">加载中...</view>
</view>
