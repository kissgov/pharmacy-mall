.page { background: #f5f5f5; min-height: 100vh; padding-bottom: 20rpx; }
.search-bar {
  position: sticky; top: 0; z-index: 100;
  padding: 16rpx 24rpx; background: #fff;
}
.search-input {
  display: flex; align-items: center;
  background: #f5f5f5; border-radius: 40rpx;
  padding: 14rpx 24rpx;
}
.search-input .icon { font-size: 28rpx; margin-right: 12rpx; }
.search-input .placeholder { font-size: 28rpx; color: #bbb; }
.banner-swiper { width: 100%; height: 320rpx; }
.banner-img { width: 100%; height: 100%; }
.category-grid {
  display: flex; flex-wrap: wrap;
  padding: 24rpx 16rpx; background: #fff;
  margin-bottom: 16rpx;
}
.category-item {
  width: 25%; display: flex; flex-direction: column;
  align-items: center; padding: 16rpx 0;
}
.cat-icon { width: 80rpx; height: 80rpx; border-radius: 50%; background: #f0faf4; }
.cat-name { font-size: 24rpx; color: #333; margin-top: 10rpx; }
.section { padding: 0 16rpx; }
.section-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 8rpx 16rpx;
}
.section-title { font-size: 32rpx; font-weight: bold; color: #333; }
.section-more { font-size: 26rpx; color: #999; }
.product-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.product-list product-card { width: calc(50% - 8rpx); }
.loading { text-align: center; padding: 40rpx; color: #999; font-size: 28rpx; }
