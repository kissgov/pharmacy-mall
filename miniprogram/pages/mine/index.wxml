<view class="page">
  <!-- 用户信息（可编辑头像和昵称） -->
  <view class="user-card">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{userInfo.avatar_url}}" class="avatar" src="{{userInfo.avatar_url}}" mode="aspectFill" />
      <view wx:else class="avatar-default">👤</view>
    </button>
    <view class="user-info">
      <input class="nickname-input" type="nickname" value="{{userInfo.nickname || ''}}" placeholder="点击设置昵称" bindblur="onNicknameBlur" />
      <text class="level">{{userInfo.member_level === 'normal' ? '普通会员' : userInfo.member_level}}</text>
    </view>
  </view>

  <!-- 订单入口 -->
  <view class="order-section">
    <view class="section-header">
      <text class="title">我的订单</text>
      <text class="more" data-url="/pages/order-list/index" bindtap="onNavTo">全部 ›</text>
    </view>
    <view class="order-grid">
      <view class="order-item" data-status="pending" bindtap="onOrderTap">
        <text class="order-icon">💳</text>
        <text class="order-label">待付款</text>
        <text wx:if="{{orderCounts.pending}}" class="badge">{{orderCounts.pending}}</text>
      </view>
      <view class="order-item" data-status="paid" bindtap="onOrderTap">
        <text class="order-icon">📦</text>
        <text class="order-label">已付款</text>
        <text wx:if="{{orderCounts.paid}}" class="badge">{{orderCounts.paid}}</text>
      </view>
      <view class="order-item" data-status="shipped" bindtap="onOrderTap">
        <text class="order-icon">🚚</text>
        <text class="order-label">已发货</text>
        <text wx:if="{{orderCounts.shipped}}" class="badge">{{orderCounts.shipped}}</text>
      </view>
      <view class="order-item" data-status="completed" bindtap="onOrderTap">
        <text class="order-icon">✅</text>
        <text class="order-label">已完成</text>
        <text wx:if="{{orderCounts.completed}}" class="badge">{{orderCounts.completed}}</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu">
    <view class="menu-item" data-url="/pages/prescription/index" bindtap="onNavTo">
      <text>我的处方</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" data-url="/pages/address-list/index" bindtap="onNavTo">
      <text>收货地址</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" data-url="/pages/coupons/index" bindtap="onNavTo">
      <text>优惠券</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item">
      <text>我的积分</text>
      <text class="value">{{userInfo.points || 0}}</text>
    </view>
    <view class="menu-item" data-url="/pages/reminder/index" bindtap="onNavTo">
      <text>用药提醒</text>
      <text class="arrow">›</text>
    </view>
    <button class="menu-item contact-btn" open-type="contact">
      <text>在线客服</text>
      <text class="arrow">›</text>
    </button>
  </view>

  <view class="menu">
    <view class="menu-item" bindtap="onClearCache">
      <text>清除缓存</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAbout">
      <text>关于我们</text>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
