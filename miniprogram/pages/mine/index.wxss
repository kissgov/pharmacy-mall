.page { background: #f5f5f5; min-height: 100vh; }

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #07c160, #06ad56);
  padding: 48rpx 32rpx;
  display: flex;
  align-items: center;
}
.avatar-btn {
  width: 128rpx; height: 128rpx;
  padding: 0; margin: 0;
  background: none;
  border: none;
  line-height: 1;
  flex-shrink: 0;
}
.avatar-btn::after { border: none; }
.avatar {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid rgba(255,255,255,0.5);
}
.avatar-default {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  border: 4rpx solid rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}
.user-info {
  margin-left: 24rpx;
}
.nickname {
  font-size: 34rpx;
  color: #fff;
  font-weight: bold;
  display: block;
}
.nickname-input {
  font-size: 34rpx;
  color: #fff;
  font-weight: bold;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0;
  background: transparent;
  border: none;
  max-width: 400rpx;
}
.nickname-input::placeholder { color: rgba(255,255,255,0.6); }
.level {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

/* 订单入口 */
.order-section {
  background: #fff;
  margin: 16rpx;
  border-radius: 12rpx;
  padding: 24rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.section-header .title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}
.section-header .more {
  font-size: 26rpx;
  color: #999;
}
.order-grid {
  display: flex;
  justify-content: space-around;
}
.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}
.order-icon {
  font-size: 48rpx;
}
.order-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}
.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #e53e3e;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
  padding: 0 6rpx;
}

/* 功能菜单 */
.menu {
  background: #fff;
  margin: 16rpx;
  border-radius: 12rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 30rpx;
  color: #333;
}
.menu-item:last-child {
  border-bottom: none;
}
.arrow {
  font-size: 28rpx;
  color: #ccc;
}
.value {
  font-size: 24rpx;
  color: #999;
}
.contact-btn {
  background: none;
  border: none;
  margin: 0;
  text-align: left;
  width: 100%;
  line-height: inherit;
}
.contact-btn::after {
  border: none;
}
