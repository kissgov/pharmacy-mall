.page { background: #f5f5f5; min-height: 100vh; }
.upload-btn {
  margin: 24rpx 16rpx; height: 88rpx; border-radius: 12rpx;
  background: #07c160; color: #fff; font-size: 30rpx;
  text-align: center; line-height: 88rpx;
}
.list { padding: 0 16rpx; }
.rx-card {
  display: flex; background: #fff; padding: 20rpx;
  border-radius: 12rpx; margin-bottom: 16rpx;
}
.rx-img { width: 120rpx; height: 120rpx; border-radius: 8rpx; background: #f5f5f5; }
.rx-info { flex: 1; margin-left: 16rpx; display: flex; flex-direction: column; justify-content: center; }
.rx-date { font-size: 24rpx; color: #999; }
.rx-status { font-size: 28rpx; font-weight: bold; margin-top: 8rpx; }
.rx-remark { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.empty { text-align: center; padding: 200rpx 0; }
.empty-icon { font-size: 100rpx; display: block; }
.empty-text { font-size: 28rpx; color: #999; margin-top: 20rpx; display: block; }
