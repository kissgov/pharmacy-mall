.page { background: #f5f5f5; min-height: 100vh; }
.img-swiper { width: 100%; height: 600rpx; }
.img { width: 100%; height: 100%; }
.img-counter {
  position: absolute; top: 560rpx; right: 24rpx;
  background: rgba(0,0,0,0.5); color: #fff; font-size: 22rpx;
  padding: 4rpx 16rpx; border-radius: 20rpx;
}
.info-card, .card {
  background: #fff; padding: 24rpx; margin: 16rpx;
  border-radius: 12rpx;
}
.price-row { display: flex; align-items: baseline; gap: 12rpx; margin-bottom: 12rpx; }
.price { font-size: 40rpx; font-weight: bold; color: #e53e3e; }
.member-price {
  font-size: 28rpx; color: #999; text-decoration: line-through;
}
.name { font-size: 32rpx; font-weight: bold; color: #333; line-height: 1.4; }
.meta { margin-top: 16rpx; }
.meta text { display: block; font-size: 24rpx; color: #999; line-height: 1.8; }
.card-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; }
.card-text { font-size: 26rpx; color: #666; line-height: 1.7; }
.warn-card { background: #fff8f5; }
.warn-title { color: #e53e3e; }
.review-item { padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.review-item:last-child { border-bottom: none; }
.review-header { display: flex; align-items: center; gap: 12rpx; }
.avatar { width: 48rpx; height: 48rpx; border-radius: 50%; background: #eee; }
.nickname { font-size: 26rpx; color: #666; }
.stars { font-size: 22rpx; }
.review-content { font-size: 26rpx; color: #333; margin-top: 10rpx; display: block; }
.review-date { font-size: 22rpx; color: #bbb; margin-top: 8rpx; display: block; }
.no-review { text-align: center; color: #999; font-size: 26rpx; padding: 20rpx 0; }

.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff; gap: 16rpx; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.bottom-bar .btn { flex: 1; height: 80rpx; border-radius: 40rpx; text-align: center; line-height: 80rpx; font-size: 30rpx; }
.btn.outline { border: 2rpx solid #07c160; color: #07c160; background: #fff; }
.btn.solid { background: #07c160; color: #fff; }

.popup-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 200;
  display: flex; align-items: flex-end;
}
.popup {
  width: 100%; background: #fff; border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 32rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}
.popup-title { font-size: 32rpx; font-weight: bold; text-align: center; display: block; margin-bottom: 32rpx; }
.qty-row { display: flex; justify-content: center; align-items: center; gap: 32rpx; }
.qty-btn {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  border: 2rpx solid #ddd; font-size: 36rpx;
  display: flex; align-items: center; justify-content: center;
}
.qty-num { font-size: 36rpx; font-weight: bold; min-width: 60rpx; text-align: center; }
.popup-confirm {
  margin-top: 32rpx; height: 80rpx; border-radius: 40rpx;
  background: #07c160; color: #fff; font-size: 30rpx;
  text-align: center; line-height: 80rpx;
}
.loading { text-align: center; padding: 200rpx 0; color: #999; }
