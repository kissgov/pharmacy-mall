.page { background: #f5f5f5; min-height: 100vh; padding-bottom: 120rpx; }
.list { padding: 16rpx; }
.reminder-card {
  background: #fff; padding: 24rpx; border-radius: 12rpx;
  margin-bottom: 16rpx; display: flex; justify-content: space-between;
}
.drug-name { font-size: 30rpx; font-weight: bold; color: #333; display: block; }
.drug-detail { font-size: 24rpx; color: #666; margin-top: 6rpx; display: block; }
.reminder-actions { display: flex; align-items: center; gap: 16rpx; }
.action { font-size: 24rpx; color: #07c160; }
.empty { text-align: center; padding: 200rpx 0; }
.empty-icon { font-size: 100rpx; display: block; }
.empty-text { font-size: 28rpx; color: #999; margin-top: 20rpx; display: block; }
.add-btn {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 88rpx; background: #07c160; color: #fff;
  font-size: 30rpx; text-align: center; line-height: 88rpx;
  padding-bottom: env(safe-area-inset-bottom);
}
.popup-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 200;
  display: flex; align-items: flex-end;
}
.popup {
  width: 100%; background: #fff; border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx; padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 80vh; overflow-y: auto;
}
.popup-title { font-size: 32rpx; font-weight: bold; text-align: center; display: block; margin-bottom: 24rpx; }
.form-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx; color: #333;
}
.label { color: #666; }
.input { flex: 1; text-align: right; color: #333; }
.popup-btns { display: flex; gap: 24rpx; margin-top: 32rpx; }
.popup-btns .btn { flex: 1; height: 80rpx; border-radius: 40rpx; text-align: center; line-height: 80rpx; font-size: 30rpx; }
.btn.cancel { background: #f5f5f5; color: #666; }
.btn.save { background: #07c160; color: #fff; }
