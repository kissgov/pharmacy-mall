.page { min-height: 100vh; background: #f5f5f5; }
.search-header {
  display: flex; align-items: center; padding: 16rpx 24rpx;
  background: #fff; padding-top: calc(16rpx + env(safe-area-inset-top));
}
.search-box {
  flex: 1; display: flex; align-items: center;
  background: #f5f5f5; border-radius: 40rpx; padding: 12rpx 20rpx;
}
.search-icon { font-size: 28rpx; margin-right: 10rpx; }
.search-input { flex: 1; font-size: 28rpx; }
.clear-btn {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: #ccc; color: #fff; font-size: 22rpx;
  display: flex; align-items: center; justify-content: center;
}
.cancel { font-size: 28rpx; color: #333; margin-left: 20rpx; white-space: nowrap; }
.results { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 16rpx; }
.results product-card { width: calc(50% - 8rpx); }
.empty { text-align: center; padding: 120rpx 0; color: #999; font-size: 28rpx; }
.section { padding: 24rpx; background: #fff; margin-top: 16rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.section-header .title { font-size: 28rpx; font-weight: bold; color: #333; }
.section-header .clear { font-size: 24rpx; color: #999; }
.tag-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tag {
  padding: 12rpx 24rpx; background: #f5f5f5;
  border-radius: 8rpx; font-size: 24rpx; color: #666;
}
.tag.hot { background: #fff5f5; color: #e53e3e; }
